generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ANALYST
  VIEWER
}

enum Sentiment {
  POS
  NEU
  NEG
}

enum FeedbackStatus {
  NEW
  REVIEWED
  ACTIONED
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  feedbacks   Feedback[]
  themes      Theme[]
  reports     Report[]
  activities  Activity[]
  invitations Invitation[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(VIEWER)
  resetToken        String?   @unique
  resetTokenExpires DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  reports      Report[]

  @@index([workspaceId])
}

model Feedback {
  id             String   @id @default(cuid())
  content        String
  channel        String
  sourceRef      String?
  customerLabel  String?

  sentiment      Sentiment?
  sentimentScore Float?
  status         FeedbackStatus @default(NEW)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  themes         FeedbackTheme[]
  embedding      Embedding?

  @@index([workspaceId])
  @@index([status])
  @@index([sentiment])
  @@index([createdAt])
}

model Theme {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#3B82F6")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  feedbacks   FeedbackTheme[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model FeedbackTheme {
  feedbackId String
  themeId    String

  confidence Float

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  theme    Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([feedbackId, themeId])
}

model Embedding {
  id         String @id @default(cuid())
  vector     Json

  feedbackId String   @unique
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
}

model Report {
  id          String   @id @default(cuid())
  title       String
  periodStart DateTime
  periodEnd   DateTime
  contentJson Json

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  generatedById String
  generatedBy   User @relation(fields: [generatedById], references: [id])

  @@index([workspaceId])
}

model Activity {
  id          String   @id @default(cuid())
  action      String
  target      String
  createdAt   DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([createdAt])
}

model Invitation {
  id          String   @id @default(cuid())
  email       String
  name        String
  role        Role     @default(VIEWER)
  token       String   @unique
  expiresAt   DateTime
  accepted    Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}